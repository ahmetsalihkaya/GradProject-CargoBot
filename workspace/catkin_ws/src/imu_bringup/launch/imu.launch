<launch>

  <node pkg="mpu_6050_driver"
        type="imu_node.py"
        name="mpu6050_driver"
        output="screen" />

  <node pkg="imu_filter_madgwick"
        type="imu_filter_node"
        name="imu_filter"
        output="screen">

    <remap from="imu/data_raw" to="/imu/data"/>

    <param name="output_frame" value="imu_link"/>
    <param name="publish_tf" value="false"/>
    <param name="use_mag" value="false"/>

    <remap from="imu/data" to="/imu/data_filtered"/>

  </node>

</launch>

