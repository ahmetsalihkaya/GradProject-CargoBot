<launch>

  <!-- Start Cartographer -->
  <node name="cartographer_node"
        pkg="cartographer_ros"
        type="cartographer_node"
        output="screen"
        args="-configuration_directory $(find cartographer_config)/config
              -configuration_basename jetbot_2d.lua
	      -load_state_filename /home/jetbot/my_map.pbstream
	      -load_frozen_state true">

    <remap from="scan" to="/scan"/>
    <remap from="imu" to="/imu/data_filtered"/>

  </node>

  <!-- Occupancy Grid -->
  <node name="occupancy_grid_node"
        pkg="cartographer_ros"
        type="cartographer_occupancy_grid_node"
        output="screen">
    <param name="resolution" value="0.05"/>
  </node>

</launch>
